# PostgreSQL
POSTGRES_USER=kb
POSTGRES_PASSWORD=change-me

# RabbitMQ
RABBITMQ_USER=kb
RABBITMQ_PASSWORD=change-me

# AI (ingestion, search, chat)
GEMINI_API_KEY=your-gemini-api-key

# Public URLs (GitHub Environment variables in prod)
CORS_ALLOWED_ORIGINS=https://kb.bookly.lv
# Leave empty for same-origin requests (/api/...). If set, use origin only — not .../api
VITE_API_BASE_URL=

# Traefik (shared bookly instance on network bookly-proxy)
TRAEFIK_NETWORK=bookly-proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
# Optional — enable when frontend Google login is implemented
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
