{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Authority": "",
    "Audience": "knowledgebase-api",
    "RequireHttpsMetadata": false
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "identity-route-root": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth"
        }
      },
      "tenant-route": {
        "ClusterId": "tenant-cluster",
        "Match": {
          "Path": "/api/tenants/{**catch-all}"
        }
      },
      "tenant-route-root": {
        "ClusterId": "tenant-cluster",
        "Match": {
          "Path": "/api/tenants"
        }
      },
      "document-route": {
        "ClusterId": "document-cluster",
        "Match": {
          "Path": "/api/documents/{**catch-all}"
        }
      },
      "document-route-root": {
        "ClusterId": "document-cluster",
        "Match": {
          "Path": "/api/documents"
        }
      },
      "search-route": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      },
      "search-route-root": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/api/search"
        }
      },
      "chat-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/api/chat/{**catch-all}"
        }
      },
      "chat-route-root": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/api/chat"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-api": {
            "Address": "https+http://identity-api"
          }
        }
      },
      "tenant-cluster": {
        "Destinations": {
          "tenant-api": {
            "Address": "https+http://tenant-api"
          }
        }
      },
      "document-cluster": {
        "Destinations": {
          "document-api": {
            "Address": "https+http://document-api"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "search-api": {
            "Address": "https+http://search-api"
          }
        }
      },
      "chat-cluster": {
        "Destinations": {
          "chat-api": {
            "Address": "https+http://chat-api"
          }
        }
      }
    }
  }
}
